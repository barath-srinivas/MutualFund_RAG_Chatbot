# LLM (Phase 2+) — Groq (free tier; OpenAI-compatible chat API)
# Get your key: https://console.groq.com/keys
GROQ_API_KEY=
LLM_PROVIDER=groq
LLM_MODEL=llama-3.3-70b-versatile
LLM_BASE_URL=https://api.groq.com/openai/v1
LLM_TEMPERATURE=0.1

# Embeddings (Phase 1+) — local BGE via sentence-transformers (no API key required)
EMBEDDING_PROVIDER=local
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
EMBEDDING_DEVICE=cpu
EMBEDDING_DIMENSIONS=384
EMBEDDING_BATCH_SIZE=32
CHROMA_COLLECTION_NAME=mf_corpus

# Citation allowlist (comma-separated registrable domains)
ALLOWED_DOMAINS=icicipruamc.com,www.icicipruamc.com,amfiindia.com,www.amfiindia.com,sebi.gov.in,www.sebi.gov.in

# Paths (relative to project root)
CORPUS_SCHEMES_PATH=corpus/schemes.yaml
VECTOR_DB_PATH=data/chroma
CORPUS_URLS_PATH=corpus/urls.yaml
CORPUS_RAW_PATH=corpus/raw
FETCH_TIMEOUT_SECONDS=60
FETCH_RETRIES=3
FETCH_RATE_LIMIT_SECONDS=1
# TLS verification for corpus fetch (uses certifi bundle; set false only for local debugging)
FETCH_SSL_VERIFY=true

# Retrieval (local BGE scores are lower than cloud APIs; default 0.30)
RETRIEVAL_MIN_SCORE=0.30
RETRIEVAL_TOP_K=6
RETRIEVAL_CANDIDATE_K=12

# Answer limits: standard type=answer uses 3 sentences; type=structured (user asks for table) uses table rows + 2-sentence summary
ANSWER_MAX_SENTENCES=3
STRUCTURED_SUMMARY_MAX_SENTENCES=2
STRUCTURED_MAX_ROWS=12

# API
API_HOST=127.0.0.1
API_PORT=8000
LOG_LEVEL=INFO

# CORS — comma-separated frontend origins (Vercel + local). Add your deployed Vercel URL.
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,https://your-app.vercel.app

# Phase 5 — ops, security, evaluation
CHAT_RATE_LIMIT_PER_MINUTE=30
METRICS_ENABLED=true

# Railway production — daily 10:00 IST refresh (API service)
ENABLE_INTERNAL_INGEST=false
INGEST_TRIGGER_SECRET=

# GitHub Actions daily-ingest.yml (repository secrets, not in .env):
# RAILWAY_API_BASE_URL=https://<your-api>.up.railway.app
# INGEST_TRIGGER_SECRET=<same as above>

# Optional Railway cron service only (if not using GitHub Actions schedule):
# INGEST_TRIGGER_URL=http://<api-service>.railway.internal:<PORT>/internal/ingest
